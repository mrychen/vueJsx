# Ignore node_modules in all nested projects
node_modules/
**/node_modules/

# Ignore build/dist output
dist/
build/
.esbuild/
.out/
.coverage/
coverage/

# Ignore lock files if you don't want to commit them across all projects
# yarn.lock
# package-lock.json
# pnpm-lock.yaml

# Ignore editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ignore system files
.DS_Store
Thumbs.db
desktop.ini

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Ignore local env files
.env
.env.*

# Ignore temporary files
*.tmp
*.temp
*.swp
*~

# Ignore generated TypeScript build outputs
*.tsbuildinfo

# Optional: ignore test snapshots and coverage reports
coverage/
*.lcov

# Optional: ignore IDE project files
*.iml
.idea/

# Optional: ignore OS-specific metadata
ehthumbs.db

# Optional: ignore local package manager cache
.pnp/
.pnp.js
# Ignore nested repository metadata
**/.git
# Optional: ignore generated lockfiles if using pnpm workspaces
.pnpm/
